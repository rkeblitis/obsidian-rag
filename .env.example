# Copy to .env and fill in ( .env is gitignored )

# Required for vault scripts: list-notes, load-vault, chunk, embed-vault
VAULT_PATH=

# Optional: defaults to ./embeddings.json (path is gitignored by default)
# EMBEDDINGS_FILE=embeddings.json

# Optional: defaults to http://localhost:11434
# OLLAMA_BASE_URL=http://localhost:11434

# Optional: path to a short vault description for ask.ts (keep local / gitignored if it names topics)
# VAULT_OVERVIEW_FILE=./vault-overview.local.md
